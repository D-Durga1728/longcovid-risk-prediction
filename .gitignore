powerbi_export/models/model_Stacking.joblib
powerbi_export/models/model_RF.joblib
powerbi_export/models/model_GB.joblib
powerbi_export/models/model_XGBoost.joblib
powerbi_export/models/model_LR.joblib

# ── Local editor / agent settings ───────────────────────────────────────────
.claude/

# ── Large analysis CSVs NOT needed by the deployed app ──────────────────────
# The app reads only powerbi_export/advanced/*.csv and the embedded PNGs.
# These raw/cleaned cohort dumps are large and unused at runtime.
powerbi_export/core_data/


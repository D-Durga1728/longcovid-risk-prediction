{
  "name": "Long COVID Clinical Theme",
  "dataColors": [
    "#1F77B4",
    "#17A2B8",
    "#2CA02C",
    "#FF7F0E",
    "#D62728",
    "#6F42C1",
    "#8C564B",
    "#7F7F7F",
    "#0B3D91",
    "#20C997"
  ],
  "background": "#FFFFFF",
  "foreground": "#1A1A2E",
  "tableAccent": "#1F77B4",
  "good": "#2CA02C",
  "neutral": "#FF7F0E",
  "bad": "#D62728",
  "maximum": "#D62728",
  "center": "#FF7F0E",
  "minimum": "#2CA02C",
  "null": "#CCCCCC",
  "textClasses": {
    "title": {
      "color": "#0B3D91",
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold"
    },
    "header": {
      "color": "#1A1A2E",
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold"
    },
    "label": {
      "color": "#1A1A2E",
      "fontSize": 10,
      "fontFace": "Segoe UI"
    },
    "callout": {
      "color": "#0B3D91",
      "fontSize": 36,
      "fontFace": "Segoe UI"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E0E0E0" } }, "radius": 6 }],
        "dropShadow": [{ "show": true, "preset": "Bottom" }],
        "title": [{ "show": true, "fontColor": { "solid": { "color": "#0B3D91" } }, "fontSize": 13, "fontFamily": "Segoe UI Semibold" }]
      }
    },
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#F5F7FA" } }, "transparency": 0 }]
      }
    }
  }
}
